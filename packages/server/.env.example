# Copy to .env and adjust. All optional — the API serves seeded fixtures
# when no database is reachable, so it runs with zero configuration.

# PostgreSQL connection string (only needed for db:migrate / db:seed / persistence)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/escape_plan

# API port
PORT=4000

# Optional AI planner rephrasing flag (OFF by default; app is fully functional without it)
ENABLE_AI_PLANNER=false
