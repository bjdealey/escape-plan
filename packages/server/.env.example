# Copy to .env and adjust. All optional — the API serves seeded fixtures
# when no database is reachable, so it runs with zero configuration.

# PostgreSQL connection string (only needed for db:migrate / db:seed / persistence)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/escape_plan

# API port
PORT=4000

# Optional AI planner rephrasing flag (OFF by default; app is fully functional without it)
ENABLE_AI_PLANNER=false

# ---------------------------------------------------------------------------
# Real integrations — ALL OPTIONAL. Absent => the seeded mock is used, so a
# fresh clone with none of these set behaves exactly as before.
# ---------------------------------------------------------------------------

# Currency rates via Frankfurter (ECB) — keyless. Set to enable live rates.
# CURRENCY_PROVIDER=frankfurter

# Public holidays via Nager.Date — keyless. Set to enable live holidays.
# HOLIDAY_PROVIDER=nager

# Climate via Open-Meteo ERA5 archive — keyless. Set to enable live weather.
# WEATHER_PROVIDER=open-meteo

# Flights via Amadeus Self-Service (needs a free developer key).
# AMADEUS_CLIENT_ID=
# AMADEUS_CLIENT_SECRET=
# AMADEUS_HOSTNAME=test.api.amadeus.com

# Calendar via Google Calendar (needs an OAuth access token; write-back always
# requires explicit user confirmation).
# GOOGLE_ACCESS_TOKEN=

# Auth: 'local' (default local dev session) or an Auth.js/Clerk provider name.
# AUTH_PROVIDER=local

# Used only for the DB integration test (CI provides a Postgres service).
# TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/escape_plan

# Multi-user groups (Phase 3). Default: seeded in-memory store (cold-start
# friendly). Set to 'postgres' to persist groups/invites/requests/shares.
# GROUPS_BACKEND=postgres

# Dev-only: the API honours an `x-user-id` request header to "act as" a seeded
# user for the multi-user demo. Ignored when AUTH_PROVIDER is a real provider or
# NODE_ENV=production. There is no env var for this — it is request-scoped.
